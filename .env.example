PORT=3010
TSN_API_BASE_URL=https://your-normal-tsn.onrender.com
# Optional aliases also accepted: TSN_BASE_URL, ORIGINAL_TSN_URL, TSN_URL, PUBLIC_TSN_URL
# Do not put /api at the end. TSN-S automatically adds /api/public/stock and /api/auth/login.
TSN_API_CONNECT_TIMEOUT_MS=30000
TSN_API_RETRY_COUNT=2
NODE_ENV=production
NODE_VERSION=20.12.2
NPM_CONFIG_AUDIT=false
NPM_CONFIG_FUND=false


# Optional but recommended: direct login against the original TSN MongoDB database.
# This fixes login even if the original TSN API login endpoint is missing/old.
# Usually this can be the SAME cluster URL as MONGODB_URI, but the database below should be your normal TSN database.
# Only set this if you want direct MongoDB fallback to the NORMAL TSN database.
# Do NOT set this to the TSN-S/tsn_stock database.
TSN_ORIGINAL_MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/tsn?retryWrites=true&w=majority
TSN_ORIGINAL_MONGODB_DATABASE=tsn
TSN_ORIGINAL_MONGODB_STATE_COLLECTION=app_state
TSN_ORIGINAL_MONGODB_STATE_ID=main
TSN_STOCK_SESSION_SECRET=make-this-a-long-random-secret

# Must match your normal TSN app if your users were created with encrypted usernames.
# Use the same TSN_DATA_ENCRYPTION_KEY from the original TSN Render service.
TSN_DATA_ENCRYPTION_KEY=your-original-tsn-data-encryption-key
TSN_OLD_DATA_ENCRYPTION_KEYS=

# MongoDB Atlas persistence using a normal connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/tsn_stock?retryWrites=true&w=majority
MONGODB_DATABASE=tsn_stock
MONGODB_COLLECTION=stockSnapshots

# Optional
TSN_STOCK_REFRESH_MS=2000
TSN_STOCK_MAX_HISTORY=302400

# Reset is disabled by default in TSN-S v1.1.9+. Do not enable it on public sites unless you really need it.
TSN_STOCK_ENABLE_RESET=false
TSN_STOCK_RESET_KEY=
TSN_STOCK_RESET_PRICE=100
TSN_STOCK_TARGET_BASE_PRICE=100
TSN_STOCK_AUTO_REBASE=true
TSN_STOCK_AUTO_REBASE_THRESHOLD=1.8


# TSN-S opening/trading hours use this timezone. Default is Europe/Copenhagen.
# Built-in schedule: 08:10-09:30, 09:50-11:15, 12:00-13:30.
TSN_STOCK_MARKET_TIMEZONE=Europe/Copenhagen

# TSNM fictional money / trading
TSNM_EARN_PER_MINUTE=10
TSNM_MAX_REWARD_MINUTES_PER_TICK=30
MONGODB_WALLET_COLLECTION=tsnMoneyWallets
MONGODB_TRADE_COLLECTION=tsnMoneyTrades

# Activity score display. 1000 means internal score 3.5 shows as 3500 points, and it can go higher.
TSN_STOCK_ACTIVITY_POINTS_MULTIPLIER=1000
TSN_STOCK_ACTIVITY_PRICE_SOFT_CAP=8


# Stability controls. These stop fake +4/-4 bouncing when metrics are effectively unchanged.
TSN_STOCK_MESSAGE_EPSILON=0.05
TSN_STOCK_POST_EPSILON=0.05
TSN_STOCK_ACTIVITY_EPSILON=0.01
TSN_STOCK_MAX_PRICE_MOVE_PER_TICK=1.25

# Down-move controls. These let the stock fall when activity drops or goes quiet.
TSN_STOCK_DOWNTURN_STRENGTH=1
TSN_STOCK_QUIET_DECAY_PER_TICK=0.08

# Anti-spam stock protection. Keeps one person from pumping TSN-S by spamming messages/posts.
TSN_STOCK_ANTI_SPAM=true
TSN_STOCK_SPAM_MESSAGE_CAP_PER_USER_PER_HOUR=8
TSN_STOCK_SPAM_POST_CAP_PER_USER_PER_HOUR=3
TSN_STOCK_SPAM_DUPLICATE_WINDOW_MS=120000
TSN_STOCK_SPAM_MIN_UNIQUE_USERS_FOR_FULL_BOOST=2

# Render/npm install safety
# Put these in Render Environment, not in package.json:
# NODE_VERSION=20.12.2
# NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
# NPM_CONFIG_PACKAGE_LOCK=false
# NPM_CONFIG_AUDIT=false
# NPM_CONFIG_FUND=false
# NPM_CONFIG_PROGRESS=false
